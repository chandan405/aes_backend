# ============================================
# AES Backend - Environment Variables
# ============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:4200

# MongoDB
# MONGO_URI=mongodb://localhost:27017/aes_db
MONGO_URI=mongodb+srv://chandanbhola65_db_user:demo123@cluster0.lno8psu.mongodb.net/?appName=Cluster0
# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_change_in_production
REFRESH_TOKEN_EXPIRES_IN=7d

# Cloudinary (https://cloudinary.com - free account)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# SMTP Configuration
# For Gmail: host=smtp.gmail.com, port=465, secure=true, or port=587, secure=false
# For Yahoo: host=smtp.mail.yahoo.com, port=465, secure=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@aes.com


# Default Admin (used by seed script)
ADMIN_NAME=Super Admin
ADMIN_PASSWORD=Admin@123456
